# 키보드 이벤트
t.listen()
t.onkeypress(turn_right, "Right")
t.onkeypress(turn_up, "Up")
t.onkeypress(turn_left, "Left")
t.onkeypress(turn_down, "Down")
# t.onkeypress(reset_game, "Escape")  # Esc 키로 재시작

# 시간 시작
countdown()

t.mainloop()